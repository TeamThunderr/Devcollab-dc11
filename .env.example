# ─── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API server ─────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devcollab:devcollab@localhost:5432/devcollab

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Both secrets must be >= 32 characters
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-string-32-chars

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# ─── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API server ─────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devcollab:devcollab@localhost:5432/devcollab

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Both secrets must be >= 32 characters
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-string-32-chars

# ─── CORS ────────────────────────────────────────────────────────────────────
