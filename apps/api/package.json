{
  "name": "@devcollab/api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src -e ts,js --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@devcollab/shared-types": "*",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/oauth2": "^7.9.0",
    "@fastify/rate-limit": "^11.1.0",
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^4.28.0",
    "fastify-type-provider-zod": "^2.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "postgres": "^3.4.9",
    "socket.io": "^4.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
